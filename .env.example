# Copy to `.env` (gitignored) and fill with your Supabase project values.
# Dashboard: Project Settings → API
#
# VITE_SUPABASE_ANON_KEY may be either:
# - the legacy long JWT labeled "anon" / "public anon", or
# - the newer default key starting with sb_publishable_ (recommended if anon returns 401).

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
